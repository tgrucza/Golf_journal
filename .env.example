# Copy this file to .env and fill in your Supabase project values.
# Find these in the Supabase dashboard: Project Settings -> API.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Also set these in the Netlify dashboard (Site settings -> Environment variables)
# so the deployed build and the coach-analysis function can see them.
# ANTHROPIC_API_KEY is server-side only (Phase 5) — never prefix it with VITE_.
ANTHROPIC_API_KEY=sk-ant-...
